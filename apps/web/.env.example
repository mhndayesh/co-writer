# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.

# Browser → FastAPI base URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ── Clerk auth ───────────────────────────────────────────────────────────────
# Publishable key is PUBLIC (it ships to the browser). From Clerk dashboard → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SECRET — used by the Next.js middleware. NEVER commit a real value.
CLERK_SECRET_KEY=
# Where Clerk's hash-routed <SignIn>/<SignUp> live, and where to land after auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/studio
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/studio
