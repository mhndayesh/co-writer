# Dev environment template. Copy to .env and fill in.
# .env is gitignored — never commit real secrets. (./run.sh seeds most of this
# automatically; this file documents what's needed if you set it up by hand.)

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./gink_dev.db

# ── Security (generate fresh values) ─────────────────────────────────────────
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_KEY_ENCRYPTION_KEY=

# ── Clerk auth ───────────────────────────────────────────────────────────────
# Public endpoints/identifiers (safe to share):
CLERK_JWKS_URL=https://YOUR-SUBDOMAIN.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://YOUR-SUBDOMAIN.clerk.accounts.dev
# SECRETS — never commit real values. From Clerk dashboard → API keys / Webhooks.
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# Legacy email+password routes stay retired unless you set this to 1 (tests use it).
# LEGACY_PASSWORD_AUTH=0

# ── LLM (set at least one provider; LM Studio is the local default) ──────────
LLM_PROVIDER=lmstudio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_EMBED_MODEL=nomic-embed-text-v1.5
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Graph & Vector (optional — services degrade gracefully if unset) ─────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=gink_dev_password
QDRANT_URL=http://localhost:6333

# ── Misc ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
REDIS_URL=
SENTRY_DSN=
